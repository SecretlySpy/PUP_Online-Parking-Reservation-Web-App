# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# --- Core ---
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=127.0.0.1,localhost
# CSRF_TRUSTED_ORIGINS=https://your-tunnel.ngrok-free.app

# --- Database ---
# Default (no DATABASE_URL set) = local SQLite, zero setup.
# To use MySQL (deployment target), install MySQL and uncomment:
# DATABASE_URL=mysql://pup_user:pup_pass@127.0.0.1:3306/pup_parking

# --- Email (dev prints to console; set SMTP for real delivery) ---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# EMAIL_USE_TLS=True
# EMAIL_TIMEOUT=10
# DEFAULT_FROM_EMAIL=PUP Parking <no-reply@pupparking.local>

# --- Privileged registration (disabled by default) ---
# Enable only for a short, controlled enrollment window. The code must be a
# non-placeholder value with at least 16 characters.
ADMIN_SIGNUP_ENABLED=False
# ADMIN_SIGNUP_CODE=generate-a-strong-random-code
# ADMIN_SIGNUP_MAX_ATTEMPTS=5
# ADMIN_SIGNUP_WINDOW_MINUTES=15

# --- PayMongo (use TEST keys during development) ---
# PAYMONGO_SECRET_KEY=sk_test_xxx
# PAYMONGO_PUBLIC_KEY=pk_test_xxx
# PAYMONGO_WEBHOOK_SECRET=whsk_xxx
# PAYMONGO_WEBHOOK_TOLERANCE_SECONDS=300
# RESERVATION_FEE_CENTS=5000
# RESERVATION_PAYMENT_GRACE_MINUTES=30
# RESERVATION_ARRIVAL_GRACE_MINUTES=15

# The simulator mutates payment state without PayMongo. It only operates when
# both this flag and DEBUG are true; production deployments must leave it off.
PAYMENT_SIMULATION_ENABLED=True

# --- Logging ---
LOG_LEVEL=INFO

# --- Site ---
# SITE_BASE_URL=http://127.0.0.1:8000
